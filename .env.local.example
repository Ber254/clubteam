# Copiá este archivo como `.env.local` y completá con tus valores de Supabase.
# (Supabase Dashboard -> Project Settings -> API)

# URL del proyecto (ej: https://xxxxxxxx.supabase.co)
NEXT_PUBLIC_SUPABASE_URL=

# Clave pública "anon" (segura para el navegador; RLS protege los datos)
NEXT_PUBLIC_SUPABASE_ANON_KEY=
